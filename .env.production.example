# Copy values into Render / Vercel env panels — do NOT commit real secrets.

# --- Required for production ---
USE_SQLITE=false
USE_LOCAL_STORAGE=false
WORKER_EAGER=false

DATABASE_URL=postgresql://USER:PASS@HOST/DB?sslmode=require

# Upstash: use the Redis URL (rediss://...), NOT the REST URL
REDIS_URL=rediss://default:PASSWORD@HOST:6379

OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_CHAT_MODEL=openai/gpt-4o-mini
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# Cloudflare R2 (S3-compatible) — free tier available
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=hover
AWS_S3_ENDPOINT_URL=https://ACCOUNT_ID.r2.cloudflarestorage.com
AWS_S3_REGION_NAME=auto

# Frontend (Vercel) — point API calls at your Render backend
# VITE_API_BASE=https://your-hover-api.onrender.com
